# Shelf Docker Compose configuration
# Copy to .env and customize as needed

# Docker Compose project name (used to namespace containers)
# COMPOSE_PROJECT_NAME=shelf-dev

# Container name
# SHELF_CONTAINER=shelf-dev

# Application port (HTTPS)
# SHELF_PORT=18889

# Host path for data volume (database, covers, certs)
# SHELF_DATA=./data-dev

# Additional DNS/IP entries for the self-signed TLS cert
# CERT_SAN=IP:192.168.1.100,DNS:shelf,DNS:localhost

# Trust CF-Connecting-IP / X-Forwarded-For headers for client IPs.
# ONLY set this when Shelf runs behind a reverse proxy that overwrites those
# headers — otherwise clients can spoof their IP to bypass login rate limiting.
# SHELF_TRUST_PROXY=1

# JWT signing key. Auto-generated and stored in the DB if unset.
# SECRET_KEY=

# Encryption key for API credentials stored in the DB. If unset, a key is
# auto-generated at data/encryption.key (kept out of DB backups either way).
# Setting it here means the data directory alone is not enough to decrypt
# stored credentials. Generate with: openssl rand -hex 32
# SHELF_ENCRYPTION_KEY=
