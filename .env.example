# Shelf Docker Compose configuration
# Copy to .env and customize as needed

# Docker Compose project name (used to namespace containers)
# COMPOSE_PROJECT_NAME=shelf-dev

# Container name
# SHELF_CONTAINER=shelf-dev

# Application port (HTTPS)
# SHELF_PORT=18889

# Host path for data volume (database, covers, certs)
# SHELF_DATA=./data-dev

# Additional DNS/IP entries for the self-signed TLS cert
# CERT_SAN=IP:192.168.1.100,DNS:shelf,DNS:localhost
